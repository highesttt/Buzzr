<UserControl
    x:Class="Buzzr.Views.ChatListControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="16,48,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Chats" FontSize="20" FontWeight="SemiBold"
                       Foreground="#F3F3F3" FontFamily="Segoe UI"/>
            <Button x:Name="NewChatBtn" Grid.Column="1"
                    Width="28" Height="28" Padding="0"
                    Background="Transparent" BorderThickness="0"
                    ToolTipService.ToolTip="New chat (Ctrl+Shift+N)">
                <FontIcon Glyph="&#xE710;" FontSize="14" Foreground="#4CC2FF"/>
            </Button>
        </Grid>

        <!-- Search -->
        <TextBox x:Name="SearchBox" Grid.Row="1"
                 PlaceholderText="Search chats... (Ctrl+K)"
                 Margin="8,0,8,4"/>

        <!-- Tab filters -->
        <StackPanel x:Name="TabBar" Grid.Row="2" Orientation="Horizontal"
                    Spacing="0" Margin="8,4,8,8">
            <Button x:Name="TabAll" Content="All" FontSize="12" Height="28"
                    Padding="10,0,10,0" Background="#2D2D2D" Foreground="#F3F3F3"
                    CornerRadius="4,0,0,4" BorderThickness="0"/>
            <Button x:Name="TabUnread" Content="Unread" FontSize="12" Height="28"
                    Padding="10,0,10,0" Background="Transparent" Foreground="#A1A1A1"
                    CornerRadius="0" BorderThickness="0"/>
            <Button x:Name="TabPinned" Content="Pinned" FontSize="12" Height="28"
                    Padding="10,0,10,0" Background="Transparent" Foreground="#A1A1A1"
                    CornerRadius="0" BorderThickness="0"/>
            <Button x:Name="TabArchived" Content="Archived" FontSize="12" Height="28"
                    Padding="10,0,10,0" Background="Transparent" Foreground="#A1A1A1"
                    CornerRadius="0" BorderThickness="0"/>
            <Button x:Name="TabLowPriority" Content="Low Priority" FontSize="12" Height="28"
                    Padding="10,0,10,0" Background="Transparent" Foreground="#A1A1A1"
                    CornerRadius="0,4,4,0" BorderThickness="0"/>
        </StackPanel>

        <!-- Chat list -->
        <ScrollViewer x:Name="ChatScroll" Grid.Row="3" Padding="4,0,4,4">
            <StackPanel x:Name="ListStack" Spacing="1"/>
        </ScrollViewer>

        <!-- Loading overlay -->
        <StackPanel x:Name="LoadingPanel" Grid.Row="3"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="12">
            <ProgressRing x:Name="LoadingRing" IsActive="True"
                          Width="32" Height="32"/>
            <TextBlock x:Name="LoadingText" Text="Loading chats..."
                       FontSize="13" Foreground="#4CC2FF" FontFamily="Segoe UI"
                       HorizontalAlignment="Center" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>
