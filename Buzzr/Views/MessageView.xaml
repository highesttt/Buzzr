<UserControl
    x:Class="Buzzr.Views.MessageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Grid Background="#1F2021">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#242424" BorderBrush="#1A1E20"
                BorderThickness="0,0,0,1" Padding="20,48,20,12">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="HeaderAvatarContainer" Grid.Column="0"
                        Visibility="Collapsed"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="HeaderTitle" Text="Select a conversation"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="#F3F3F3" FontFamily="Segoe UI"/>
                    <StackPanel Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center">
                        <Border x:Name="HeaderNetDot" Width="8" Height="8"
                                CornerRadius="4" Visibility="Collapsed"/>
                        <TextBlock x:Name="HeaderSubtitle" FontSize="12"
                                   Foreground="#A1A1A1" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="HeaderParticipants" FontSize="11"
                                   Foreground="#636363" FontFamily="Segoe UI"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>

                <!-- Search in chat button -->
                <Button x:Name="SearchInChatBtn" Grid.Column="2"
                        Width="32" Height="32" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        Visibility="Collapsed"
                        ToolTipService.ToolTip="Search in chat">
                    <FontIcon Glyph="&#xE721;" FontSize="14" Foreground="#A1A1A1"/>
                </Button>
            </Grid>
        </Border>

        <!-- In-chat search bar -->
        <Border x:Name="ChatSearchBar" Grid.Row="1" Background="#242424"
                BorderBrush="#1A1E20" BorderThickness="0,0,0,1"
                Padding="16,8,16,8" Visibility="Collapsed">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ChatSearchBox" Grid.Column="0"
                         PlaceholderText="Search messages..."/>
                <Button x:Name="ChatSearchClose" Grid.Column="1"
                        Width="28" Height="28" Padding="0"
                        Background="Transparent" BorderThickness="0">
                    <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="#A1A1A1"/>
                </Button>
            </Grid>
        </Border>

        <!-- Messages scroll -->
        <ScrollViewer x:Name="MsgScroll" Grid.Row="2"
                      Padding="16,8,16,8" Visibility="Collapsed">
            <StackPanel x:Name="MsgStack" Spacing="2"/>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel x:Name="EmptyState" Grid.Row="2"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="8">
            <FontIcon Glyph="&#xE8BD;" FontSize="40" Foreground="#636363"
                      HorizontalAlignment="Center"/>
            <TextBlock Text="Select a conversation" FontSize="16"
                       Foreground="#A1A1A1" FontFamily="Segoe UI"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Choose a chat from the list to start messaging"
                       FontSize="13" Foreground="#636363" FontFamily="Segoe UI"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Loading -->
        <ProgressRing x:Name="LoadingRing" Grid.Row="2"
                      IsActive="False" Width="32" Height="32"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Visibility="Collapsed"/>

        <!-- Edit bar (shown when editing a message) -->
        <Border x:Name="EditBar" Grid.Row="3"
                Background="#2B2B2B" BorderBrush="#1A1E20"
                BorderThickness="0,1,0,0" Padding="16,8,16,8"
                Visibility="Collapsed">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xE70F;" FontSize="14" Foreground="#4CC2FF"
                          VerticalAlignment="Center"/>
                <TextBlock x:Name="EditBarText" Grid.Column="1" Text="Editing message"
                           FontSize="12" Foreground="#A1A1A1" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <Button x:Name="EditCancelBtn" Grid.Column="2"
                        Content="Cancel" FontSize="12" Height="28"
                        Padding="8,0,8,0" Background="Transparent"
                        Foreground="#FF4343" BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- Reply bar (shown when replying) -->
        <Border x:Name="ReplyBar" Grid.Row="3"
                Background="#2B2B2B" BorderBrush="#1A1E20"
                BorderThickness="0,1,0,0" Padding="16,8,16,8"
                Visibility="Collapsed">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="3" Height="24"
                        Background="#4CC2FF" CornerRadius="2"
                        VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                    <TextBlock x:Name="ReplyBarSender" FontSize="11" FontWeight="SemiBold"
                               Foreground="#4CC2FF" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="ReplyBarText" FontSize="12"
                               Foreground="#A1A1A1" FontFamily="Segoe UI"
                               MaxLines="1" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Button x:Name="ReplyCancelBtn" Grid.Column="2"
                        Width="24" Height="24" Padding="0"
                        Background="Transparent" BorderThickness="0">
                    <FontIcon Glyph="&#xE711;" FontSize="10" Foreground="#A1A1A1"/>
                </Button>
            </Grid>
        </Border>

        <!-- Attachment staging area -->
        <Border x:Name="AttachmentPreview" Grid.Row="4"
                Background="#2B2B2B" BorderBrush="#1A1E20"
                BorderThickness="0,1,0,0" Padding="12,8,12,8"
                Visibility="Collapsed">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Enabled">
                <StackPanel x:Name="AttachmentPreviewStack"
                            Orientation="Horizontal" Spacing="8"/>
            </ScrollViewer>
        </Border>

        <!-- Scheduled messages indicator -->
        <Border x:Name="ScheduledBar" Grid.Row="5"
                Background="#2B2B2B" BorderBrush="#1A1E20"
                BorderThickness="0,1,0,0" Padding="16,6,16,6"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE823;" FontSize="12" Foreground="#4CC2FF"
                          VerticalAlignment="Center"/>
                <TextBlock x:Name="ScheduledBarText" FontSize="12"
                           Foreground="#A1A1A1" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Composer -->
        <Border x:Name="Composer" Grid.Row="6"
                Background="#242424" BorderBrush="#1A1E20"
                BorderThickness="0,1,0,0" Padding="16,12,16,16"
                Visibility="Collapsed">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Attach button -->
                <Button x:Name="AttachBtn" Grid.Column="0"
                        Width="36" Height="36" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Attach file">
                    <FontIcon Glyph="&#xE723;" FontSize="16" Foreground="#A1A1A1"/>
                </Button>

                <TextBox x:Name="MsgInput" Grid.Column="1"
                         PlaceholderText="Type a message..."
                         AcceptsReturn="False"
                         AllowDrop="True"
                         DragOver="OnDragOver"
                         Drop="OnDrop"/>

                <!-- GIF button -->
                <Button x:Name="GifBtn" Grid.Column="2"
                        Width="36" Height="36" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Send GIF">
                    <TextBlock Text="GIF" FontSize="10" FontWeight="Bold" Foreground="#A1A1A1"/>
                </Button>

                <!-- Emoji button -->
                <Button x:Name="EmojiBtn" Grid.Column="3"
                        Width="36" Height="36" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Emoji (Win+.)">
                    <FontIcon Glyph="&#xE76E;" FontSize="16" Foreground="#A1A1A1"/>
                </Button>

                <!-- Send button -->
                <Button x:Name="SendBtn" Grid.Column="4"
                        Width="40" Height="36" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        IsEnabled="False">
                    <FontIcon Glyph="&#xE724;" FontSize="16" Foreground="#4CC2FF"/>
                </Button>

                <!-- Schedule send button -->
                <Button x:Name="ScheduleBtn" Grid.Column="5"
                        Width="28" Height="36" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Schedule send">
                    <FontIcon Glyph="&#xE823;" FontSize="14" Foreground="#A1A1A1"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
