<UserControl
    x:Class="Buzzr.Views.MessageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <UserControl.Resources>
        <Style x:Key="NoFlickerButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="1"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="1"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="0.8"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Padding="{TemplateBinding Padding}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    BorderBrush="{TemplateBinding BorderBrush}">
                                <ContentPresenter
                                    Content="{TemplateBinding Content}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                            <Border x:Name="HoverOverlay"
                                    Background="#15FFFFFF"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Opacity="0" IsHitTestVisible="False"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#1F2021">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#242424" BorderBrush="#1A1E20"
                BorderThickness="0,0,0,1" Padding="20,48,20,12">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="HeaderAvatarContainer" Grid.Column="0"
                        Visibility="Collapsed"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="HeaderTitle" Text="Select a conversation"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="#F3F3F3" FontFamily="Segoe UI"/>
                    <StackPanel Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center">
                        <Border x:Name="HeaderNetDot" Width="8" Height="8"
                                CornerRadius="4" Visibility="Collapsed"/>
                        <TextBlock x:Name="HeaderSubtitle" FontSize="12"
                                   Foreground="#A1A1A1" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="HeaderParticipants" FontSize="11"
                                   Foreground="#636363" FontFamily="Segoe UI"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>

                <Button x:Name="SearchInChatBtn" Grid.Column="2"
                        Width="32" Height="32" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        Visibility="Collapsed"
                        ToolTipService.ToolTip="Search in chat">
                    <FontIcon Glyph="&#xE721;" FontSize="14" Foreground="#A1A1A1"/>
                </Button>
            </Grid>
        </Border>

        <Border x:Name="ChatSearchBar" Grid.Row="1" Background="#242424"
                BorderBrush="#1A1E20" BorderThickness="0,0,0,1"
                Padding="16,8,16,8" Visibility="Collapsed">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ChatSearchBox" Grid.Column="0"
                         PlaceholderText="Search messages..."/>
                <Button x:Name="ChatSearchClose" Grid.Column="1"
                        Width="28" Height="28" Padding="0"
                        Background="Transparent" BorderThickness="0">
                    <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="#A1A1A1"/>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer x:Name="MsgScroll" Grid.Row="2"
                      Padding="16,8,16,8" Visibility="Collapsed">
            <StackPanel x:Name="MsgStack" Spacing="2"/>
        </ScrollViewer>

        <StackPanel x:Name="EmptyState" Grid.Row="2"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="8">
            <FontIcon Glyph="&#xE8BD;" FontSize="40" Foreground="#636363"
                      HorizontalAlignment="Center"/>
            <TextBlock Text="Select a conversation" FontSize="16"
                       Foreground="#A1A1A1" FontFamily="Segoe UI"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Choose a chat from the list to start messaging"
                       FontSize="13" Foreground="#636363" FontFamily="Segoe UI"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <ProgressRing x:Name="LoadingRing" Grid.Row="2"
                      IsActive="False" Width="32" Height="32"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Visibility="Collapsed"/>

        <Border x:Name="EditBar" Grid.Row="3"
                Background="#2B2B2B" BorderBrush="#1A1E20"
                BorderThickness="0,1,0,0" Padding="16,8,16,8"
                Visibility="Collapsed">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xE70F;" FontSize="14" Foreground="{StaticResource AccentBrush}"
                          VerticalAlignment="Center"/>
                <TextBlock x:Name="EditBarText" Grid.Column="1" Text="Editing message"
                           FontSize="12" Foreground="#A1A1A1" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <Button x:Name="EditCancelBtn" Grid.Column="2"
                        Content="Cancel" FontSize="12" Height="28"
                        Padding="8,0,8,0" Background="Transparent"
                        Foreground="#FF4343" BorderThickness="0"/>
            </Grid>
        </Border>

        <Border x:Name="ReplyBar" Grid.Row="3"
                Background="#2B2B2B" BorderBrush="#1A1E20"
                BorderThickness="0,1,0,0" Padding="16,8,16,8"
                Visibility="Collapsed">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="3" Height="24"
                        Background="{StaticResource AccentBrush}" CornerRadius="2"
                        VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                    <TextBlock x:Name="ReplyBarSender" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="ReplyBarText" FontSize="12"
                               Foreground="#A1A1A1" FontFamily="Segoe UI"
                               MaxLines="1" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Button x:Name="ReplyCancelBtn" Grid.Column="2"
                        Width="24" Height="24" Padding="0"
                        Background="Transparent" BorderThickness="0">
                    <FontIcon Glyph="&#xE711;" FontSize="10" Foreground="#A1A1A1"/>
                </Button>
            </Grid>
        </Border>

        <Border x:Name="AttachmentPreview" Grid.Row="4"
                Background="#2B2B2B" BorderBrush="#1A1E20"
                BorderThickness="0,1,0,0" Padding="12,8,12,8"
                Visibility="Collapsed">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Enabled">
                <StackPanel x:Name="AttachmentPreviewStack"
                            Orientation="Horizontal" Spacing="8"/>
            </ScrollViewer>
        </Border>

        <Border x:Name="ScheduledBar" Grid.Row="5"
                Background="#2B2B2B" BorderBrush="#1A1E20"
                BorderThickness="0,1,0,0" Padding="16,6,16,6"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE823;" FontSize="12" Foreground="{StaticResource AccentBrush}"
                          VerticalAlignment="Center"/>
                <TextBlock x:Name="ScheduledBarText" FontSize="12"
                           Foreground="#A1A1A1" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border x:Name="MentionPopup" Grid.Row="2"
                Background="#2B2B2B" BorderBrush="#3A3A3A"
                BorderThickness="1" CornerRadius="8"
                Padding="4" Visibility="Collapsed"
                VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                Margin="16,0,16,4">
            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="MentionList" Spacing="0"/>
            </ScrollViewer>
        </Border>

        <StackPanel x:Name="TypingIndicator" Grid.Row="6"
                    Orientation="Horizontal" Spacing="6"
                    Padding="20,4,20,2" Visibility="Collapsed"
                    Background="#242424"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,72">
            <TextBlock Text="•••" FontSize="10" Foreground="#A1A1A1" VerticalAlignment="Center"/>
            <TextBlock x:Name="TypingIndicatorText" FontSize="11" Foreground="#A1A1A1"
                       FontStyle="Italic" VerticalAlignment="Center"/>
        </StackPanel>

        <Border x:Name="Composer" Grid.Row="6"
                Background="#242424" BorderBrush="#1A1E20"
                BorderThickness="0,1,0,0" Padding="16,12,16,16"
                Visibility="Collapsed">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="AttachBtn" Grid.Column="0"
                        Width="36" Height="36" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Attach file">
                    <FontIcon Glyph="&#xE723;" FontSize="16" Foreground="#A1A1A1"/>
                </Button>

                <TextBox x:Name="MsgInput" Grid.Column="1"
                         PlaceholderText="Type a message..."
                         AcceptsReturn="False"
                         AllowDrop="True"
                         DragOver="OnDragOver"
                         Drop="OnDrop"/>

                <Button x:Name="GifBtn" Grid.Column="2"
                        Width="36" Height="36" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Send GIF">
                    <TextBlock Text="GIF" FontSize="10" FontWeight="Bold" Foreground="#A1A1A1"/>
                </Button>

                <Button x:Name="EmojiBtn" Grid.Column="3"
                        Width="36" Height="36" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Emoji (Win+.)">
                    <FontIcon Glyph="&#xE76E;" FontSize="16" Foreground="#A1A1A1"/>
                </Button>

                <Button x:Name="SendBtn" Grid.Column="4"
                        Width="40" Height="36" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        IsEnabled="False">
                    <FontIcon Glyph="&#xE724;" FontSize="16" Foreground="{StaticResource AccentBrush}"/>
                </Button>

                <Button x:Name="ScheduleBtn" Grid.Column="5"
                        Width="28" Height="36" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Schedule send">
                    <FontIcon Glyph="&#xE823;" FontSize="14" Foreground="#A1A1A1"/>
                </Button>
            </Grid>
        </Border>
        <Grid x:Name="ImageOverlay" Grid.RowSpan="7"
              Visibility="Collapsed" Opacity="0">
            <Grid.Background>
                <SolidColorBrush Color="#000000" Opacity="0.9"/>
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button x:Name="ImageOverlayClose" Grid.Row="0"
                    HorizontalAlignment="Right" Margin="16,48,16,0"
                    Width="36" Height="36" Padding="0"
                    Background="#40FFFFFF" BorderThickness="0" CornerRadius="18"
                    ToolTipService.ToolTip="Close (Esc)">
                <FontIcon Glyph="&#xE711;" FontSize="14" Foreground="White"/>
            </Button>

            <ScrollViewer x:Name="ImageOverlayScroll" Grid.Row="1"
                          ZoomMode="Enabled"
                          MinZoomFactor="1" MaxZoomFactor="10"
                          HorizontalScrollMode="Enabled" VerticalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          ManipulationMode="All">
                <Grid x:Name="ImageOverlayContainer"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image x:Name="ImageOverlayImg"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
