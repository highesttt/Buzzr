<Page
    x:Class="Buzzr.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#202020">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Height="48" Padding="8,0,16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BackBtn"
                        Click="BackBtn_Click"
                        Background="Transparent" BorderThickness="0"
                        Width="36" Height="36" Padding="0" CornerRadius="4">
                    <FontIcon Glyph="&#xE72B;" FontSize="14"
                              Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </Button>
                <TextBlock Text="Settings" FontSize="12"
                           VerticalAlignment="Center" Margin="4,0,0,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="468">
                <AutoSuggestBox x:Name="SearchBox"
                                PlaceholderText="Find a setting"
                                TextChanged="SearchBox_TextChanged"
                                CornerRadius="16">
                    <AutoSuggestBox.Resources>
                        <Thickness x:Key="TextControlThemePadding">32,5,10,6</Thickness>
                    </AutoSuggestBox.Resources>
                </AutoSuggestBox>
                <FontIcon Glyph="&#xE721;" FontSize="13"
                          HorizontalAlignment="Left" VerticalAlignment="Center"
                          Margin="10,0,0,0" IsHitTestVisible="False"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Grid>
        </Grid>

        <NavigationView x:Name="NavView" Grid.Row="1"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="False"
                        PaneDisplayMode="Left"
                        OpenPaneLength="320"
                        SelectionChanged="NavView_SelectionChanged">

            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>
            </NavigationView.Resources>

            <NavigationView.PaneHeader>
                <Button x:Name="ProfileCardBtn"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="8"
                        Padding="12"
                        Margin="16,4,16,12"
                        Click="ProfileCardBtn_Click">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid x:Name="SidebarAvatarContainer" Width="40" Height="40">
                            <Border x:Name="SidebarAvatarFallback" CornerRadius="20" Background="{ThemeResource SystemAccentColorLight2}">
                                <TextBlock x:Name="SidebarAvatarInitial" Text="?"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="SidebarAvatarImageBorder" CornerRadius="20" Visibility="Collapsed">
                                <Image x:Name="SidebarAvatarImage" Width="40" Height="40" Stretch="UniformToFill"/>
                            </Border>
                        </Grid>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                            <TextBlock x:Name="SidebarUsername" Text="..."
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock x:Name="SidebarEmail" Text="..."
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Button>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Preferences" Tag="preferences" Icon="Setting" Margin="12,1,12,1"/>
                <NavigationViewItem Content="Storage" Tag="storage" Icon="Save" Margin="12,1,12,1"/>
                <NavigationViewItem Content="About" Tag="about" Margin="12,1,12,1">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <ScrollViewer Padding="24,8,24,24">
                <StackPanel Width="600" HorizontalAlignment="Center">
                    <TextBlock x:Name="HeaderText" Text="Profile" FontSize="28" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,12"/>
                    <StackPanel x:Name="ContentArea" Spacing="8">

                        <StackPanel x:Name="ProfilePanel" Spacing="8">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid x:Name="AvatarContainer" Width="56" Height="56">
                                        <Border x:Name="AvatarFallback" CornerRadius="28" Background="{ThemeResource SystemAccentColorLight2}">
                                            <TextBlock x:Name="AvatarInitial" Text="?"
                                                       FontSize="22" FontWeight="Bold"
                                                       Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border x:Name="AvatarImageBorder" CornerRadius="28" Visibility="Collapsed">
                                            <Image x:Name="AvatarImage" Width="56" Height="56" Stretch="UniformToFill"/>
                                        </Border>
                                    </Grid>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock x:Name="UsernameText" Text="..."
                                                   FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock x:Name="EmailText" Text="..."
                                                   FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel>
                                        <TextBlock Text="Connection" FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                            <Ellipse x:Name="ConnectionDot" Width="8" Height="8" Fill="{ThemeResource SystemFillColorSuccessBrush}"/>
                                            <TextBlock x:Name="ConnectionText" Text="Connected"
                                                       FontSize="13"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="User ID" FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock x:Name="UserIdText" Text="..."
                                                   FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   IsTextSelectionEnabled="True" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Button x:Name="SignOutBtn" Content="Sign out"
                                    HorizontalAlignment="Stretch" Height="36"
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    CornerRadius="4"/>
                        </StackPanel>

                        <StackPanel x:Name="PreferencesPanel" Spacing="8" Visibility="Collapsed">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Open on startup" FontSize="14"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Launch Buzzr when Windows starts"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="StartupToggle" Grid.Column="1"
                                                  VerticalAlignment="Center" MinWidth="0"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="StoragePanel" Spacing="8" Visibility="Collapsed">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="10">
                                    <Grid>
                                        <TextBlock Text="Avatar cache" FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock x:Name="AvatarCacheText" Text="..."
                                                   FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="Message database" FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock x:Name="DbSizeText" Text="..."
                                                   FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="Total" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock x:Name="TotalSizeText" Text="..."
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Button x:Name="ClearCacheBtn" Content="Clear all caches"
                                    HorizontalAlignment="Stretch" Height="36"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    CornerRadius="4"/>
                        </StackPanel>

                        <StackPanel x:Name="AboutPanel" Spacing="8" Visibility="Collapsed">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="24">
                                <StackPanel HorizontalAlignment="Center" Spacing="6">
                                    <Image Source="ms-appx:///Assets/buzzr-logo.png"
                                           Width="64" Height="64" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Buzzr" FontSize="20" FontWeight="Bold"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="VersionText" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Unofficial Windows client for Beeper"
                                               FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Built with WinUI 3" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    <HyperlinkButton Content="highest.dev" NavigateUri="https://highest.dev"
                                                     HorizontalAlignment="Center" FontSize="12" Padding="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </NavigationView>
    </Grid>
</Page>
