<Page
    x:Class="BeeperWinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark"
    Background="#1F2021">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar with back button -->
        <Grid Grid.Row="0" Background="#242424" BorderBrush="#1A1E20"
              BorderThickness="0,0,0,1" Padding="12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BackBtn" Grid.Column="0"
                    Background="Transparent" BorderThickness="0"
                    VerticalAlignment="Center" Padding="8,6"
                    ToolTipService.ToolTip="Back">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="#A1A1A1"/>
                    <TextBlock Text="Back" FontSize="13" Foreground="#A1A1A1"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock Grid.Column="1" Text="Settings" FontSize="16" FontWeight="SemiBold"
                       Foreground="#F3F3F3" VerticalAlignment="Center"
                       HorizontalAlignment="Center" Margin="0,0,60,0"/>
        </Grid>

        <!-- Settings content -->
        <ScrollViewer Grid.Row="1" Padding="0,16,0,16">
            <StackPanel HorizontalAlignment="Center" Width="480" Spacing="20">

                <!-- Storage section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Storage" FontSize="14" FontWeight="SemiBold"
                               Foreground="#F3F3F3" Margin="4,0,0,4"/>

                    <Border Background="#2B2B2B" BorderBrush="#1A1E20"
                            BorderThickness="1" CornerRadius="8"
                            Padding="16,14">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Avatar cache" FontSize="13"
                                               Foreground="#F3F3F3"/>
                                    <TextBlock x:Name="AvatarCacheInfo" Text="Calculating..."
                                               FontSize="11" Foreground="#808080"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#3A3A3A"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Chat cache" FontSize="13"
                                               Foreground="#F3F3F3"/>
                                    <TextBlock x:Name="ChatCacheInfo" Text="Calculating..."
                                               FontSize="11" Foreground="#808080"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#3A3A3A"/>

                            <Button x:Name="ClearCacheBtn" Content="Clear all caches"
                                    HorizontalAlignment="Stretch" Height="36"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Account section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Account" FontSize="14" FontWeight="SemiBold"
                               Foreground="#F3F3F3" Margin="4,0,0,4"/>

                    <Border Background="#2B2B2B" BorderBrush="#1A1E20"
                            BorderThickness="1" CornerRadius="8"
                            Padding="16,14">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Username" FontSize="13"
                                               Foreground="#F3F3F3"/>
                                    <TextBlock x:Name="UsernameText" Text="..."
                                               FontSize="11" Foreground="#808080"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#3A3A3A"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Connection mode" FontSize="13"
                                               Foreground="#F3F3F3"/>
                                    <TextBlock x:Name="ConnectionModeText" Text="..."
                                               FontSize="11" Foreground="#808080"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#3A3A3A"/>

                            <Button x:Name="SignOutBtn" Content="Sign out"
                                    HorizontalAlignment="Stretch" Height="36"
                                    Foreground="#FF4343"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
