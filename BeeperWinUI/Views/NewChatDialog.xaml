<ContentDialog
    x:Class="BeeperWinUI.Views.NewChatDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="New Chat"
    PrimaryButtonText="Start Chat"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    RequestedTheme="Dark">
    <StackPanel Spacing="12" MinWidth="350">
        <TextBlock Text="Select an account and find a contact to start a new conversation."
                   TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <ComboBox x:Name="AccountPicker" Header="Account" HorizontalAlignment="Stretch"
                  PlaceholderText="Select account..." />

        <TextBox x:Name="ContactSearch" Header="Contact" PlaceholderText="Search by name, phone, or email..." />

        <ProgressRing x:Name="SearchProgress" IsActive="False" Width="20" Height="20"
                      HorizontalAlignment="Left" Visibility="Collapsed"/>

        <ListView x:Name="ContactList" MaxHeight="200" SelectionMode="Single" />

        <TextBox x:Name="FirstMessage" Header="Message (optional)" PlaceholderText="Type your first message..."
                 AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="80" />
    </StackPanel>
</ContentDialog>
