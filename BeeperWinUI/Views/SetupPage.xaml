<Page
    x:Class="BeeperWinUI.Views.SetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark"
    Background="#1F2021">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="440">

            <!-- Logo -->
            <Border Width="64" Height="64" CornerRadius="16"
                    Background="#4CC2FF" HorizontalAlignment="Center"
                    Margin="0,0,0,12">
                <TextBlock Text="B" FontSize="32" FontWeight="SemiBold"
                           Foreground="Black" FontFamily="Segoe UI"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="Beeper" FontSize="28" FontWeight="SemiBold"
                       Foreground="#F3F3F3" FontFamily="Segoe UI"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="Connect to Beeper Desktop" FontSize="14"
                       Foreground="#A1A1A1" FontFamily="Segoe UI"
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <!-- Instructions card -->
            <Border Background="#2B2B2B" BorderBrush="#1A1E20"
                    BorderThickness="1" CornerRadius="8"
                    Padding="20,16,20,16">
                <StackPanel Spacing="6">
                    <TextBlock Text="1. Open Beeper Desktop" FontSize="13"
                               Foreground="#A1A1A1" FontFamily="Segoe UI"/>
                    <TextBlock Text="2. Go to Settings &#x2192; Developers" FontSize="13"
                               Foreground="#A1A1A1" FontFamily="Segoe UI"/>
                    <TextBlock Text="3. Enable the API and copy your token" FontSize="13"
                               Foreground="#A1A1A1" FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- Token input card -->
            <Border Background="#2B2B2B" BorderBrush="#1A1E20"
                    BorderThickness="1" CornerRadius="8"
                    Padding="24,20,24,20" Margin="0,16,0,0">
                <StackPanel Spacing="12">

                    <InfoBar x:Name="ErrorBar" Severity="Error" IsOpen="False"
                             IsClosable="True" Margin="0,0,0,4"/>

                    <InfoBar x:Name="StatusBar" Severity="Informational" IsOpen="False"
                             IsClosable="False" Margin="0,0,0,4"/>

                    <TextBlock Text="API Token" FontSize="13" FontWeight="SemiBold"
                               Foreground="#F3F3F3" FontFamily="Segoe UI"/>

                    <PasswordBox x:Name="TokenBox"
                                 PlaceholderText="Paste your Beeper API token"/>

                    <Button x:Name="ConnectBtn" Content="Connect"
                            HorizontalAlignment="Stretch" Height="36"
                            Style="{StaticResource AccentButtonStyle}"/>

                    <ProgressRing x:Name="ConnectProgress"
                                  IsActive="False" Width="24" Height="24"
                                  HorizontalAlignment="Center"
                                  Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Beeper Desktop must be running" FontSize="12"
                       Foreground="#636363" FontFamily="Segoe UI"
                       HorizontalAlignment="Center" Margin="0,16,0,0"/>
        </StackPanel>
    </Grid>
</Page>
