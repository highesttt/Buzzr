<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Buzzr"
           Version="$(var.Version)"
           Manufacturer="highest"
           UpgradeCode="f7a8b9c0-1d2e-3f4a-5b6c-7d8e9f0a1b2c"
           InstallerVersion="500"
           Compressed="yes"
           Scope="perMachine">

    <SummaryInformation Description="Buzzr - Native Beeper Client for Windows" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Buzzr is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="BuzzrIcon" SourceFile="$(var.IconPath)" />
    <Property Id="ARPPRODUCTICON" Value="BuzzrIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/highesttt/Buzzr" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/highesttt/Buzzr" />

    <Feature Id="Main" Title="Buzzr" Description="Native Beeper client for Windows" Level="1"
             ConfigurableDirectory="INSTALLFOLDER">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="DesktopShortcut" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Buzzr" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="StartMenuDir" Name="Buzzr" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.SourceDir)\**" />
    </ComponentGroup>

    <Component Id="DesktopShortcut" Guid="*" Directory="DesktopFolder">
      <Shortcut Id="DesktopLink"
                Name="Buzzr"
                Target="[INSTALLFOLDER]Buzzr.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="BuzzrIcon" />
      <RegistryValue Root="HKCU" Key="Software\Buzzr" Name="DesktopShortcut"
                     Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Component Id="StartMenuShortcut" Guid="*" Directory="StartMenuDir">
      <Shortcut Id="StartMenuLink"
                Name="Buzzr"
                Target="[INSTALLFOLDER]Buzzr.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="BuzzrIcon" />
      <RegistryValue Root="HKCU" Key="Software\Buzzr" Name="StartMenuShortcut"
                     Type="integer" Value="1" KeyPath="yes" />
      <RemoveFolder Id="RemoveStartMenuDir" On="uninstall" />
    </Component>
  </Fragment>
</Wix>
